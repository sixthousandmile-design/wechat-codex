# Relay process settings
RELAY_DB_PATH=relay.sqlite3
RELAY_WORKER_TOKEN=replace-with-a-long-random-token
ALLOWED_SENDERS=whatsapp:15551234567,wechat:o_replace_with_openid
MAX_REPLY_CHARS=1800
JOB_LEASE_SECONDS=3600

# WhatsApp Cloud API settings
WHATSAPP_VERIFY_TOKEN=replace-with-meta-webhook-verify-token
WHATSAPP_APP_SECRET=replace-with-meta-app-secret
WHATSAPP_ACCESS_TOKEN=replace-with-whatsapp-cloud-api-token
WHATSAPP_PHONE_NUMBER_ID=replace-with-phone-number-id
WHATSAPP_GRAPH_API_BASE=https://graph.facebook.com/v23.0

# WeChat service/test account settings
WECHAT_TOKEN=replace-with-wechat-message-push-token
# Optional: only needed if you want async completion messages pushed back to WeChat.
# For production this should be a fresh access_token managed outside this minimal relay.
WECHAT_ACCESS_TOKEN=

# Local worker settings
RELAY_URL=https://your-public-relay.example
CODEX_WORKSPACE=C:\Users\xinleiy\Weizmann Institute Dropbox\Xinlei Yue\codes
# Use "codex" if it is on PATH. Otherwise use the full codex.exe path from:
# C:\Users\<you>\.vscode\extensions\openai.chatgpt-*\bin\windows-x86_64\codex.exe
CODEX_COMMAND=codex
CODEX_TIMEOUT_SECONDS=900
POLL_INTERVAL_SECONDS=5
WORKER_LOG_DIR=worker_logs
